# Copy this file to `.env` (in the same directory) before running
# `docker compose up`. The real `.env` is gitignored — never commit it.

# PostgreSQL credentials. The same values are consumed by:
#   - the `postgres` service (initialises the cluster)
#   - the `api` service (assembles ConnectionStrings__LunaDb)
POSTGRES_USER=luna
POSTGRES_PASSWORD=changeme
POSTGRES_DB=luna
